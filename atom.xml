  <entry>
    <title>npm script warns permission errors in the cache directory</title>
    <link href="https://memolog.org/2022/npm-script-warns-permission-errors-in-the-cache-directory.html"/>
    <id>https://memolog.org/2022/npm-script-warns-permission-errors-in-the-cache-directory.html</id>
